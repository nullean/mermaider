<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Sugiyama</RootNamespace>
    <Description>Lightweight Sugiyama (layered graph) layout engine for .NET. Zero external dependencies, allocation-aware, AOT-friendly.</Description>
    <NoWarn>CS1591</NoWarn>
    <PackageTags>sugiyama;layout;graph;dagre;layered;directed;hierarchical</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Mermaid" PublicKey="" />
    <InternalsVisibleTo Include="Sugiyama.Tests" PublicKey="" />
    <InternalsVisibleTo Include="Mermaid.Benchmarks" PublicKey="" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="README.md" Pack="true" PackagePath="README.md" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\nuget-icon.png" Pack="true" PackagePath="nuget-icon.png" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
