<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Mermaider</RootNamespace>
    <Description>Render Mermaid diagrams to SVG. Pure .NET, no browser, no DOM dependencies.</Description>
    <NoWarn>CS1591</NoWarn>
    <PackageTags>mermaid;diagram;svg;flowchart;sequence-diagram;visualization</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Mermaider.Tests" PublicKey="" />
    <InternalsVisibleTo Include="Mermaider.Layout.Msagl" PublicKey="" />
    <InternalsVisibleTo Include="Mermaider.Benchmarks" PublicKey="" />
  </ItemGroup>
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="README.md" />
    <None Include="..\..\nuget-icon.png" Pack="true" PackagePath="nuget-icon.png" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../Sugiyama/Sugiyama.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.ObjectPool" />
  </ItemGroup>
</Project>
